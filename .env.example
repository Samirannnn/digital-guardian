# Supabase — copy this file to .env and fill in your values
# Get these from: https://supabase.com/dashboard/project/<your-project-id>/settings/api

SUPABASE_URL="https://<your-project-id>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"

VITE_SUPABASE_URL="https://<your-project-id>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"
VITE_SUPABASE_PROJECT_ID="your-project-id-here"
